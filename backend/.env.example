# ================================================
# CLERK AUTHENTICATION CONFIGURATION
# ================================================
# Get these keys from: https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# ================================================
# DATABASE CONFIGURATION
# ================================================
MONGO_URI=mongodb://localhost:27017/mailguard

# ================================================
# GMAIL OAUTH CONFIGURATION
# ================================================
# Get these from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/gmail/callback

# ================================================
# ML SERVICE CONFIGURATION
# ================================================
ML_SERVICE_URL=http://ml-service:5001

# ================================================
# SERVER CONFIGURATION
# ================================================
PORT=5000
NODE_ENV=development

# ================================================
# OPTIONAL: SCHEDULER CONFIGURATION
# ================================================
# Cron schedule for automatic model retraining (default: 0 2 * * * - 2 AM daily)
RETRAIN_SCHEDULE=0 2 * * *
# Cron schedule for email scanning job (default: 0 2 * * * - 2 AM daily)
SCAN_SCHEDULE=0 2 * * *
